{
  "buildCommand": null,
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/record/:path*", "destination": "/index.html" },
    { "source": "/crate/:path*", "destination": "/index.html" }
  ]
}
